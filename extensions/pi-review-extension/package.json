{
  "name": "@review-loop/pi-extension",
  "version": "0.0.1",
  "type": "module",
  "description": "Lightweight plan review loop for Pi coding agent",
  "author": "backnotprop",
  "license": "MIT OR Apache-2.0",
  "pi": {
    "extensions": ["./"]
  },
  "files": [
    "index.ts",
    "server.ts",
    "review-core.ts",
    "feedback-templates.ts",
    "README.md",
    "plan-review.html",
    "diff-review.html"
  ],
  "scripts": {
    "build:plan-review-ui": "mkdir -p dist-plan-review && cp plan-review.html dist-plan-review/index.html",
    "build:diff-review-ui": "mkdir -p dist-diff-review && cp diff-review.html dist-diff-review/index.html",
    "build": "bun run build:plan-review-ui && bun run build:diff-review-ui"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@vitejs/plugin-react": "^5.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "vite": "^6.2.0",
    "vite-plugin-singlefile": "^2.0.3"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.53.0"
  }
}
